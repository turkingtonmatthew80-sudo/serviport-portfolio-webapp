# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
TELEGRAM_BOT_TOKEN="MY_TELEGRAM_BOT_TOKEN"
TELEGRAM_CHAT_ID="MY_TELEGRAM_CHAT_ID"

# FIRECRAWL_API_KEY: Required for Firecrawl maritime data scraping
# APIFY_API_KEY: Required for Apify Marine Traffic Scraper
APIFY_API_KEY=
FIRECRAWL_API_KEY="MY_FIRECRAWL_API_KEY"

# AISSTREAM_API_KEY: Required for real-time marine traffic data
AISSTREAM_API_KEY="MY_AISSTREAM_API_KEY"

# TELEGRAM_BOT_TOKEN: El token del bot de Telegram obtenido desde el BotFather
TELEGRAM_BOT_TOKEN=

# TELEGRAM_CHAT_ID: El ID del chat/canal donde el bot enviará las solicitudes
TELEGRAM_CHAT_ID=
