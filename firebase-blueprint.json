{
  "entities": {
    "userProfile": {
      "title": "User Profile",
      "description": "Information about a user.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string"
        },
        "razonSocial": {
          "type": "string"
        },
        "rif": {
          "type": "string"
        },
        "roles": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["email", "razonSocial", "rif", "roles"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": {
        "$ref": "#/entities/userProfile"
      },
      "description": "User profiles, indexed by their Firebase UID."
    }
  }
}
